ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=
ROCKETRIDE_GEMINI_APIKEY=
ROCKETRIDE_MISTRAL_APIKEY=

PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
PHOTON_ACCOUNT_ID=

# Required for live calorie/macro grounding (free at https://fdc.nal.usda.gov/api-key-signup)
USDA_FDC_API_KEY=
GOOGLE_PLACES_API_KEY=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8787/strava/callback
# Start local OAuth callback server (for localhost redirect URI)
SPOT_STRAVA_CALLBACK=1
# Auto-refresh Strava burn at most every N ms per user (default 300000 = 5 min)
SPOT_STRAVA_SYNC_INTERVAL_MS=300000

SPOT_DAILY_CALORIES=2200
SPOT_DAILY_PROTEIN=150
SPOT_DAILY_CARBS=220
SPOT_DAILY_FAT=70
SPOT_PIPELINE_PATH=../../pipelines/spot.pipe
SPOT_MEDIA_PIPELINE_PATH=../../pipelines/spot-media.pipe
SPOT_PIPELINE_MODE=chat
SPOT_ENABLE_TERMINAL=1
SPOT_ECHO_MODE=0
SPOT_DEMO_MODE=0
# Set to 1 to skip RocketRide entirely (USDA-only text parsing)
SPOT_SKIP_ROCKETRIDE=0
SPOT_STATE_PATH=../../.spot-state.json
SPOT_TIMEZONE=America/Los_Angeles
